# RML environment configuration — copy to `.env.local` for local development.
# Only this `.env.example` is committed. Real values go in `.env.local`
# (git-ignored). Never commit secrets. See CLAUDE.md §7.

# --- App ---
# Public base URL of the deployed app. Used for absolute links and metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase ---
# The Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=""
# Anon (browser-safe) key. RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key. SERVER-ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Upstash Redis (rate limiting) ---
# REST endpoint and token for the Upstash Redis database used by
# `@upstash/ratelimit`. SERVER-ONLY.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
